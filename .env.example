# ===== REQUIRED =====
BOT_TOKEN=your_bot_token_from_botfather

# ===== ADMIN (comma-separated Telegram IDs) =====
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# ===== DATABASE =====
# For local Termux testing, leave as-is (SQLite)
# On Railway, PostgreSQL URL is auto-provided — DO NOT set manually
DATABASE_URL=sqlite:///godzilla.db

# ===== OPTIONAL =====
# Discord webhook for admin notifications
DISCORD_WEBHOOK_URL=

# Gemini API (for AI features — Phase 2)
GEMINI_API_KEY=

# ===== UPI PAYMENT (Direct Payment) =====
# Your UPI ID where users will send payments
UPI_ID=yourname@okhdfcbank
# Display name (shown in UPI app)
UPI_NAME=GODZILLA
# QR code filename — place your PNG in web/static/ folder
UPI_QR_FILENAME=upi_qr.png

# ===== RAZORPAY (OPTIONAL — leave empty if using UPI only) =====
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Webhook server port (Railway sets this automatically)
PORT=8080

# ===== ADMIN WEB PANEL =====
# Default admin login (change password on first login!)
ADMIN_WEB_USER=admin
ADMIN_WEB_PASS=godzilla123

# Your Railway public URL (get from Railway → Settings → Networking → Generate Domain)
# Example: https://godzilla-bot-production.up.railway.app
WEB_PANEL_URL=

# Random string for Flask session security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change-this-to-a-long-random-string
